# =============================================================================
# AI Sales Intelligence Platform — Environment Variables
# Copy to .env and adjust for your machine (Windows/macOS/Linux).
# =============================================================================

# Application
APP_NAME=AI Sales Intelligence Platform
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
API_KEY_HEADER=X-API-Key

# CORS (comma-separated origins for the React dashboard)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://frontend:80

# Database (Docker Compose defaults)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=aisales
POSTGRES_PASSWORD=aisales_secret
POSTGRES_DB=aisales
DATABASE_URL=postgresql+asyncpg://aisales:aisales_secret@postgres:5432/aisales

# LLM provider: ollama | openai  (swap without code changes)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Embeddings / local NLP
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
FAISS_INDEX_PATH=./data/faiss/index
SPACY_MODEL=en_core_web_sm

# Crawler
CRAWLER_MAX_PAGES=8
CRAWLER_TIMEOUT_SECONDS=30
CRAWLER_USER_AGENT=AISalesIntelligenceBot/1.0 (+https://localhost)

# Rate limiting
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Bootstrap admin (created on first startup if missing)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=Admin123!
BOOTSTRAP_ADMIN_API_KEY=dev-api-key-change-me

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000/api/v1
