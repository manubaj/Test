{
  "name": "celestial-horoscope",
  "version": "1.0.0",
  "description": "A beautiful astrology app for Android - Your cosmic guide to the stars",
  "main": "www/index.html",
  "scripts": {
    "start": "npx http-server www -p 3000",
    "build": "echo 'Static files ready in www/'",
    "cap:init": "npx cap init 'Celestial Horoscope' com.celestial.horoscope --web-dir www",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "android:build": "cd android && ./gradlew assembleDebug",
    "android:apk": "npm run cap:sync && npm run android:build"
  },
  "keywords": [
    "astrology",
    "horoscope",
    "zodiac",
    "android",
    "capacitor"
  ],
  "author": "Celestial Apps",
  "license": "MIT",
  "dependencies": {
    "@capacitor/android": "^5.0.0",
    "@capacitor/core": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.0.0",
    "http-server": "^14.1.1"
  }
}
